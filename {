mod ipc;

use iced::{
    widget::{button, column, container, row, text, text_input, checkbox, pick_list},
    Element, Length, Subscription, Theme, Task,
    widget::button::{primary, text as btn_text, danger},
    widget::container::{rounded_box, transparent},
};
use razermapper_common::DeviceInfo;
use std::path::PathBuf;

pub struct State {
    devices: Vec<DeviceInfo>,
    macros: Vec<razermapper_common::MacroEntry>,
    selected_device: Option<usize>,
    status: String,
    loading: bool,
    recording: bool,
    recording_macro_name: Option<String>,
    daemon_connected: bool,
    new_macro_name: String,
    socket_path: PathBuf,
}

impl Default for State {
    fn default() -> Self {
        let socket_path = if cfg!(target_os = "linux") {
            std::env::var("XDG_RUNTIME_DIR")
                .map(|dir| PathBuf::from(format!("{}/razermapper.sock", dir)))
                .unwrap_or_else(|_| PathBuf::from("/tmp/razermapper.sock"))
        } else if cfg!(target_os = "macos") {
            PathBuf::from("/tmp/razermapper.sock")
        } else {
            std::env::temp_dir().join("razermapper.sock")
        };
        State {
            devices: Vec::new(),
            macros: Vec::new(),
            selected_device: None,
            status: "Initializing...".to_string(),
            loading: false,
            recording: false,
            recording_macro_name: None,
            daemon_connected: false,
            new_macro_name: String::new(),
            socket_path,
        }
    }
}

#[derive(Debug, Clone)]
pub enum Message {
    LoadDevices,
    DevicesLoaded(Result<Vec<DeviceInfo>, String>),
    LoadMacros,
    MacrosLoaded(Result<Vec<razermapper_common::MacroEntry>, String>),
    DeviceSelected(usize),
    PlayMacro(String),
    RecordMacro(String),
    StopRecording,
    DeleteMacro(String),
    MacroRecorded(razermapper_common::MacroEntry, String),
    SaveProfile,
    LoadProfile(String),
    ProfileLoaded(Result<(String, usize), String>),
    UpdateMacroName(String),
    CheckDaemonConnection,
    DaemonStatusChanged(bool),
}

fn initialize(_flags: ()) -> (State, Task<Message>) {
    let initial_state = State::default();
    let initial_commands = Task::batch([
        Task::perform(async { Message::CheckDaemonConnection }, |msg| msg),
        Task::perform(async { Message::LoadDevices }, |msg| msg),
    ]);
    (initial_state, initial_commands)
}

fn update(state: &mut State, message: Message) -> Task<Message> {
    match message {
        Message::CheckDaemonConnection => {
            let socket_path = state.socket_path.clone();
            Task::perform(
                async move {
                    match ipc::IpcClient::connect(socket_path).await {
                        Ok(_) => true,
                        Err(_) => false,
                    }
                },
                |connected| Message::DaemonStatusChanged(connected),
            )
        }
        Message::DaemonStatusChanged(connected) => {
            state.daemon_connected = connected;
            if connected {
                state.status = "Connected to daemon".to_string();
                return Task::batch([
                    Task::perform(async { Message::LoadDevices }, |msg| msg),
                    Task::perform(async { Message::LoadMacros }, |msg| msg),
                ]);
            } else {
                state.status = "Daemon not running. Please start razermapperd.".to_string();
            }
            Task::none()
        }
        Message::LoadDevices => {
            if !state.daemon_connected {
                state.status = "Cannot load devices: daemon not connected".to_string();
                return Task::none();
            }
            state.loading = true;
            let socket_path = state.socket_path.clone();
            Task::perform(
                async move {
                    let client = match ipc::IpcClient::connect(socket_path).await {
                        Ok(client) => client,
                        Err(e) => return Err(format!("Failed to connect: {}", e)),
                    };
                    match client.get_devices().await {
                        Ok(devices) => Ok(devices),
                        Err(e) => Err(format!("Failed to load devices: {}", e)),
                    }
                },
                |result| Message::DevicesLoaded(result),
            )
        }
        Message::DevicesLoaded(result) => {
            state.loading = false;
            match result {
                Ok(devices) => {
                    state.devices = devices;
                    if !state.devices.is_empty() && state.selected_device.is_none() {
                        state.selected_device = Some(0);
                    }
                    state.status = format!("Loaded {} devices", state.devices.len());
                }
                Err(e) => {
                    state.status = e;
                }
            }
            Task::none()
        }
        Message::LoadMacros => {
            if !state.daemon_connected {
                state.status = "Cannot load macros: daemon not connected".to_string();
                return Task::none();
            }
            let socket_path = state.socket_path.clone();
            Task::perform(
                async move {
                    let client = match ipc::IpcClient::connect(socket_path).await {
                        Ok(client) => client,
                        Err(e) => return Err(format!("Failed to connect: {}", e)),
                    };
                    match client.list_macros().await {
                        Ok(macros) => Ok(macros),
                        Err(e) => Err(format!("Failed to load macros: {}", e)),
                    }
                },
                |result| Message::MacrosLoaded(result),
            )
        }
        Message::MacrosLoaded(result) => {
            match result {
                Ok(macros) => {
                    state.macros = macros;
                    state.status = format!("Loaded {} macros", state.macros.len());
                }
                Err(e) => {
                    state.status = e;
                }
            }
            Task::none()
        }
        Message::DeviceSelected(index) => {
            if index < state.devices.len() {
                state.selected_device = Some(index);
                state.status = format!("Selected device: {}", state.devices[index].name);
            }
            Task::none()
        }
        Message::PlayMacro(name) => {
            if !state.daemon_connected {
                state.status = "Cannot play macro: daemon not connected".to_string();
                return Task::none();
            }
            let socket_path = state.socket_path.clone();
            state.status = format!("Playing macro: {}", name);
            Task::perform(
                async move {
                    let client = match ipc::IpcClient::connect(socket_path).await {
                        Ok(client) => client,
                        Err(e) => return Err(format!("Failed to connect: {}", e)),
                    };
                    match client.test_macro(&name).await {
                        Ok(_) => format!("Successfully played macro: {}", name),
                        Err(e) => format!("Failed to play macro: {}", e)),
                    }
                },
                |_msg| {
                    Message::LoadMacros
                },
            )
        }
        Message::RecordMacro(name) => {
            if !state.daemon_connected {
                state.status = "Cannot record macro: daemon not connected".to_string();
                return Task::none();
            }
            if state.recording {
                state.status = "Already recording a macro".to_string();
                return Task::none();
            }
            if name.is_empty() {
                state.status = "Please enter a name for macro".to_string();
                return Task::none();
            }
            if let Some(index) = state.selected_device {
                let device_path = state.devices[index].path.to_string_lossy().to_string();
                let socket_path = state.socket_path.clone();
                state.recording = true;
                state.recording_macro_name = Some(name.clone());
                state.status = format!("Recording macro ' on device '", name, state.devices[index].name);
                return Task::perform(
                    async move {
                        let client = match ipc::IpcClient::connect(socket_path).await {
                            Ok(client) => client,
                            Err(e) => return Err(format!("Failed to connect: {}", e)),
                        };
                        match client.start_recording_macro(&device_path, &name).await {
                            Ok(_) => format!("Started recording macro: {}", name),
                            Err(e) => format!("Failed to start recording: {}", e)),
                        }
                    },
                    |_msg| {
                        Message::LoadMacros
                    },
                );
            } else {
                state.status = "No device selected for recording".to_string();
            }
            Task::none()
        }
        Message::StopRecording => {
            if !state.recording {
                return Task::none();
            }
            let socket_path = state.socket_path.clone();
            state.status = "Stopping recording...".to_string();
            Task::perform(
                async move {
                    let client = match ipc::IpcClient::connect(socket_path).await {
                        Ok(client) => client,
                        Err(e) => return Err(format!("Failed to connect: {}", e)),
                    };
                    match client.stop_recording_macro().await {
                        Ok(macro_entry) => {
                            Ok(macro_entry)
                        }
                        Err(e) => Err(format!("Failed to stop recording: {}", e)),
                    }
                },
                |result| {
                    match result {
                        Ok(macro_entry) => {
                            let status_msg = format!("Stopped recording. Created macro: {}", macro_entry.name);
                            Message::MacroRecorded(macro_entry, status_msg)
                        }
                        Err(e) => {
                            Message::MacrosLoaded(Err(e))
                        }
                    }
                }
            )
        }
        Message::DeleteMacro(name) => {
            if !state.daemon_connected {
                state.status = "Cannot delete macro: daemon not connected".to_string();
                return Task::none();
            }
            let socket_path = state.socket_path.clone();
            state.status = format!("Deleting macro: {}", name);
            Task::perform(
                async move {
                    let client = match ipc::IpcClient::connect(socket_path).await {
                        Ok(client) => client,
                        Err(e) => return Err(format!("Failed to connect: {}", e)),
                    };
                    match client.delete_macro(&name).await {
                        Ok(_) => format!("Successfully deleted macro: {}", name),
                        Err(e) => format!("Failed to delete macro: {}", e)),
                    }
                },
                |_| {
                    Message::LoadMacros
                },
            )
        }
        Message::SaveProfile => {
            if !state.daemon_connected {
                state.status = "Cannot save profile: daemon not connected".to_string();
                return Task::none();
            }
            let profile_name = "default".to_string();
            let socket_path = state.socket_path.clone();
            state.status = format!("Saving profile: {}", profile_name);
            Task::perform(
                async move {
                    let client = match ipc::IpcClient::connect(socket_path).await {
                        Ok(client) => client,
                        Err(e) => return Err(format!("Failed to connect: {}", e)),
                    };
                    match client.save_profile(&profile_name).await {
                        Ok((name, count)) => Ok((name, count)),
                        Err(e) => Err(format!("Failed to save profile: {}", e)),
                    }
                },
                |result| Message::ProfileLoaded(result),
            )
        }
        Message::ProfileLoaded(result) => {
            match result {
                Ok((name, count)) => {
                    state.status = format!("Saved profile ' with {} macros", name, count);
                }
                Err(e) => {
                    state.status = e;
                }
            }
            Task::none()
        }
        Message::MacroRecorded(macro_entry, status_msg) => {
            state.recording = false;
            state.recording_macro_name = None;
            state.status = status_msg;
            if let Some(index) = state.macros.iter().position(|m| m.name == macro_entry.name) {
                state.macros[index] = macro_entry;
            } else {
                state.macros.push(macro_entry);
            }
            Task::none()
        }
        Message::LoadProfile(_name) => {
            state.status = "Profile loading not implemented yet".to_string();
            Task::none()
        }
        Message::UpdateMacroName(name) => {
            state.new_macro_name = name;
            Task::none()
        }
    }
}

fn view(state: &State) -> Element<_, Message
